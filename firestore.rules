rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Montador de treino — um documento por coach
    match /coaches/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Gestão de alunos — um documento por coach (separado do montador)
    match /gestao/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Academia (inventário + catálogo de exercícios) — um documento por coach
    match /academia/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Portal do Aluno — fatia publicada por aluno, em portal/{email}.
    //  - o ALUNO lê apenas o documento cujo id == o e-mail logado dele;
    //  - o COACH (quem possui um doc gestao/{uid}) publica/atualiza qualquer um.
    match /portal/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Avisos da Academia — mural único, publicado pelo coach e lido por todos.
    //  - qualquer aluno autenticado LÊ;
    //  - só o COACH (dono de gestao/{uid}) publica.
    match /avisosPortal/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Ranking do box (gamificação) — doc único publicado pelo coach, lido por todos.
    match /rankingPortal/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Desafios da semana — lista única publicada pelo coach, lida por todos.
    match /desafiosPortal/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Progresso dos desafios por aluno (dias cumpridos + conclusões).
    //  - o ALUNO lê/grava só o seu; o COACH (dono de gestao/{uid}) lê.
    match /desafios/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Nutrição Básica — gasto calórico de treino, um doc por aluno.
    //  - o ALUNO lê/grava só o doc do próprio e-mail;
    //  - o COACH (dono de gestao/{uid}) pode ler (acompanhamento).
    match /gastoTreinos/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Consentimento LGPD (termo de adesão) — um doc por aluno.
    //  - o ALUNO lê/grava o seu; o COACH (dono de gestao/{uid}) lê (auditoria).
    match /consentimentos/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Registro de cargas (carga × reps por exercício) — um doc por aluno.
    //  - o ALUNO lê/grava o seu; o COACH (dono de gestao/{uid}) lê e grava (registrar por ele).
    match /cargas/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Leads da landing (formulário de aula experimental) — captação pública.
    //  - QUALQUER visitante pode CRIAR um lead (sem login — é a landing), mas
    //    só com os campos e tamanhos esperados (evita lixo/abuso);
    //  - ninguém de fora LÊ, EDITA ou APAGA (nem o próprio autor);
    //  - só o COACH (dono de gestao/{uid}) lê/atualiza/apaga (acompanhar funil).
    match /leads/{id} {
      allow create: if request.resource.data.keys().hasOnly(['nome', 'whatsapp', 'objetivo', 'horario', 'origem', 'status', 'criadoEm', 'indicadoPor'])
        && request.resource.data.nome is string && request.resource.data.nome.size() > 0 && request.resource.data.nome.size() < 100
        && request.resource.data.whatsapp is string && request.resource.data.whatsapp.size() > 0 && request.resource.data.whatsapp.size() < 30
        && request.resource.data.status == 'novo'
        && (!('indicadoPor' in request.resource.data) || (request.resource.data.indicadoPor is string && request.resource.data.indicadoPor.size() < 100));
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }

    // Caixa de entrada do aluno → coach (foto nova + feedbacks pós-treino).
    //  - o ALUNO lê/escreve apenas a própria caixa (id == e-mail logado);
    //  - o COACH (dono de gestao/{uid}) lê e limpa (merge para gestao/{uid}).
    match /portalInbox/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/gestao/$(request.auth.uid));
    }
  }
}
