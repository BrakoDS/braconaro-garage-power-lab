rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Montador de treino — um documento por coach
    match /coaches/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Gestão de alunos — um documento por coach (separado do montador)
    match /gestao/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Academia (inventário + catálogo de exercícios) — um documento por coach
    match /academia/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
